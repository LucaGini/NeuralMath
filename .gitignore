backend/pgdata/
pgdata/
postgres-data/

# Python Compilation & Caching (Backend & Agents)
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
.nox/
.tox/
.cache/
pip-log.txt
pip-delete-this-directory.txt
.ipynb_checkpoints

# Python Virtual Environments
.venv/
venv/
ENV/
env/
active_env/

# Node & Frontend (React/Vite)
frontend/node_modules/
node_modules/
frontend/dist/
frontend/build/
frontend/out/
.eslintcache
.prettiercache
.parcel-cache

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDEs, Editors & System Metadata
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
.DS_Store
Thumbs.db
ehthumbs.db
